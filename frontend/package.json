{
  "name": "rela-frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "build:e2e": "vue-tsc -b && vite build --mode development",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css}\"",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "stress": "tsx stress/cli.ts",
    "dupes": "jscpd src --ignore \"**/*.test.ts\" --reporters console"
  },
  "dependencies": {
    "@fontsource/open-sans": "^5.2.7",
    "@pinia/colada": "^1.3.1",
    "axios": "^1.16.0",
    "dompurify": "^3.4.5",
    "easymde": "^2.21.0",
    "font-awesome": "^4.7.0",
    "marked": "^18.0.3",
    "mermaid": "^11.15.0",
    "pinia": "^3.0.4",
    "rrule": "^2.8.1",
    "slim-select": "^3.4.3",
    "vue": "^3.5.35",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@pinia/testing": "^1.0.3",
    "@testing-library/vue": "^8.0.3",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^25.8.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^10.9.2",
    "fast-check": "^4.8.0",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "jscpd": "^4.2.4",
    "prettier": "^3.8.3",
    "source-map": "^0.7.6",
    "tsx": "^4.22.3",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.5",
    "vue-eslint-parser": "^10.4.1",
    "vue-tsc": "^3.3.3"
  }
}
