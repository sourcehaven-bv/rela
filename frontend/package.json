{
  "name": "rela-frontend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,vue,css}\"",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "stress": "tsx stress/cli.ts",
    "coverage:check": "node scripts/coverage-baseline.js check",
    "coverage:generate": "node scripts/coverage-baseline.js generate",
    "dupes": "jscpd src --ignore \"**/*.test.ts\" --reporters console"
  },
  "dependencies": {
    "axios": "^1.6.7",
    "dompurify": "^3.3.3",
    "easymde": "^2.20.0",
    "marked": "^17.0.4",
    "mermaid": "^11.14.0",
    "pinia": "^2.1.7",
    "rrule": "^2.8.1",
    "slim-select": "^3.4.3",
    "vue": "^3.5.33",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@pinia/testing": "^0.1.6",
    "@testing-library/vue": "^8.0.3",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vitest/coverage-v8": "^1.6.0",
    "@vue/test-utils": "^2.4.8",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^9.33.0",
    "fast-check": "^4.6.0",
    "globals": "^17.5.0",
    "happy-dom": "^14.7.1",
    "jscpd": "^4.0.8",
    "prettier": "^3.8.1",
    "source-map": "^0.7.6",
    "tsx": "^4.21.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.57.0",
    "vite": "^5.1.6",
    "vitest": "^1.6.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.0.6"
  }
}
