#!/bin/bash

# Pre-commit hook to check code quality before committing
# Install with: make install-hooks

set -e

echo "🔍 Running pre-commit checks..."
echo ""

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track if any check fails
FAILED=0

# Check 1: Format code
echo "1️⃣  Checking code formatting..."
UNFORMATTED=$(gofmt -l . 2>&1 | grep -v "^vendor/" || true)
if [ -n "$UNFORMATTED" ]; then
    echo -e "${YELLOW}⚠️  Some files are not formatted. Running gofmt...${NC}"
    gofmt -w .
    echo -e "${GREEN}✅ Files formatted${NC}"
else
    echo -e "${GREEN}✅ All files are properly formatted${NC}"
fi
echo ""

# Check 2: Run linter
echo "2️⃣  Running linter..."
if ! golangci-lint run --timeout=5m; then
    echo -e "${RED}❌ Linter found issues${NC}"
    echo "Run 'make lint-fix' to auto-fix some issues"
    FAILED=1
else
    echo -e "${GREEN}✅ Linter passed${NC}"
fi
echo ""

# Check 3: Run tests
echo "3️⃣  Running tests..."
if ! go test -race -coverprofile=coverage.out -covermode=atomic ./... > /dev/null 2>&1; then
    echo -e "${RED}❌ Tests failed${NC}"
    echo "Run 'make test' to see details"
    FAILED=1
else
    echo -e "${GREEN}✅ Tests passed${NC}"
fi
echo ""

# Check 4: Check coverage
echo "4️⃣  Checking coverage thresholds..."
if [ -f coverage.out ]; then
    if ! ./scripts/check-coverage.sh coverage.out > /dev/null 2>&1; then
        echo -e "${YELLOW}⚠️  Coverage thresholds not met${NC}"
        echo "Run 'make coverage-check' to see details"
        echo -e "${YELLOW}Note: This is a warning, commit will proceed${NC}"
        # Don't fail on coverage - just warn
    else
        echo -e "${GREEN}✅ Coverage thresholds met${NC}"
    fi
    rm -f coverage.out coverage.txt
else
    echo -e "${YELLOW}⚠️  No coverage data found${NC}"
fi
echo ""

# Final result
if [ $FAILED -eq 1 ]; then
    echo -e "${RED}❌ Pre-commit checks failed${NC}"
    echo "Fix the issues and try again"
    exit 1
fi

echo -e "${GREEN}✅ All pre-commit checks passed!${NC}"
echo ""

exit 0
