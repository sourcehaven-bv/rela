#!/bin/bash
# Combined tmux screen capture and deduplication tool
# Captures tmux pane screenshots at regular intervals and optionally deduplicates them

set -e

# Default configuration
SESSION_NAME="rela-demo"
OUTPUT_DIR="screendumps"
INTERVAL=0.5
MODE="capture"  # capture, dedupe, or both

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Print usage
usage() {
    cat << EOF
Usage: $(basename "$0") [OPTIONS] [MODE]

Combined tmux screen capture and deduplication tool.

MODES:
    capture         Capture tmux pane screenshots (default)
    dedupe          Remove duplicate consecutive screenshots
    both            Capture and then dedupe when stopped

OPTIONS:
    -s SESSION      Tmux session name (default: $SESSION_NAME)
    -o DIR          Output directory (default: $OUTPUT_DIR)
    -i INTERVAL     Capture interval in seconds (default: $INTERVAL)
    -h              Show this help message

EXAMPLES:
    # Capture screenshots from default session
    $(basename "$0")

    # Capture from specific session with custom interval
    $(basename "$0") -s my-session -i 1.0 capture

    # Deduplicate existing screenshots
    $(basename "$0") dedupe

    # Capture and auto-dedupe when stopped
    $(basename "$0") both

EOF
    exit 0
}

# Parse command line arguments
while getopts "s:o:i:h" opt; do
    case $opt in
        s) SESSION_NAME="$OPTARG" ;;
        o) OUTPUT_DIR="$OPTARG" ;;
        i) INTERVAL="$OPTARG" ;;
        h) usage ;;
        *) usage ;;
    esac
done

shift $((OPTIND-1))

# Get mode from remaining arguments
if [ $# -gt 0 ]; then
    MODE="$1"
fi

# Validate mode
case "$MODE" in
    capture|dedupe|both) ;;
    *)
        echo -e "${RED}Error: Invalid mode '$MODE'${NC}"
        echo "Valid modes: capture, dedupe, both"
        exit 1
        ;;
esac

#
# CAPTURE FUNCTION
#
capture_screenshots() {
    echo -e "${GREEN}=== Starting Screen Capture ===${NC}"
    echo "Session:  $SESSION_NAME"
    echo "Output:   $OUTPUT_DIR"
    echo "Interval: ${INTERVAL}s"
    echo ""
    echo -e "${YELLOW}Press Ctrl+C to stop${NC}"
    echo ""

    # Create output directory
    mkdir -p "$OUTPUT_DIR"

    # Find starting counter (continue from existing files)
    counter=1
    existing_files=($(ls -1 "$OUTPUT_DIR"/screen_*.txt 2>/dev/null | sort))
    if [ ${#existing_files[@]} -gt 0 ]; then
        last_file="${existing_files[-1]}"
        # Extract number from filename like screen_0023.txt
        last_num=$(basename "$last_file" | sed 's/screen_\([0-9]*\)\.txt/\1/' | sed 's/^0*//')
        if [ -n "$last_num" ]; then
            counter=$((last_num + 1))
            echo -e "${BLUE}Continuing from screenshot #$counter${NC}"
            echo ""
        fi
    fi

    # Trap Ctrl+C to clean up
    local should_dedupe=false
    if [ "$MODE" = "both" ]; then
        should_dedupe=true
    fi

    trap "echo -e '\n\n${GREEN}Stopped. Captured $counter screenshots.${NC}'; \
          if $should_dedupe; then \
              echo ''; \
              dedupe_screenshots; \
          fi; \
          exit 0" INT

    while true; do
        # Format counter with leading zeros (e.g., 0001, 0002, etc.)
        filename=$(printf "%s/screen_%04d.txt" "$OUTPUT_DIR" "$counter")

        # Capture tmux pane
        if tmux capture-pane -t "$SESSION_NAME" -p > "$filename" 2>/dev/null; then
            echo -e "${GREEN}✓${NC} Captured: $(basename "$filename")"
            ((counter++))
        else
            echo -e "${RED}Error: Could not capture pane from session '$SESSION_NAME'${NC}"
            echo "Make sure the session exists: tmux ls"
            exit 1
        fi

        # Wait before next capture
        sleep "$INTERVAL"
    done
}

#
# DEDUPE FUNCTION
#
dedupe_screenshots() {
    echo -e "${GREEN}=== Deduplicating Screen Dumps ===${NC}"
    echo "Directory: $OUTPUT_DIR"
    echo ""

    if [ ! -d "$OUTPUT_DIR" ]; then
        echo -e "${RED}Error: Directory '$OUTPUT_DIR' does not exist${NC}"
        exit 1
    fi

    # Get sorted list of screen dump files
    files=($(ls -1 "$OUTPUT_DIR"/screen_*.txt 2>/dev/null | sort))

    if [ ${#files[@]} -eq 0 ]; then
        echo "No screen dump files found"
        return 0
    fi

    echo "Found ${#files[@]} total screen dumps"
    echo ""

    removed_count=0
    kept_count=1
    prev_file="${files[0]}"

    echo -e "${GREEN}✓${NC} Keeping: $(basename "$prev_file")"

    # Compare each file with the previous one
    for ((i=1; i<${#files[@]}; i++)); do
        current_file="${files[$i]}"

        # Compare files using cmp (faster than diff for binary comparison)
        if cmp -s "$prev_file" "$current_file"; then
            # Files are identical - remove the duplicate
            rm "$current_file"
            echo -e "${RED}✗${NC} Removed: $(basename "$current_file") (duplicate of $(basename "$prev_file"))"
            ((removed_count++))
        else
            # Files are different - keep it and make it the new reference
            echo -e "${GREEN}✓${NC} Keeping: $(basename "$current_file")"
            prev_file="$current_file"
            ((kept_count++))
        fi
    done

    echo ""
    echo -e "${BLUE}Summary:${NC}"
    echo "  Total files processed: ${#files[@]}"
    echo "  Unique files kept: $kept_count"
    echo "  Duplicates removed: $removed_count"
    echo ""

    # Optionally renumber remaining files
    if [ "$removed_count" -gt 0 ]; then
        read -p "Renumber remaining files sequentially? (y/N) " -n 1 -r
        echo
        if [[ $REPLY =~ ^[Yy]$ ]]; then
            echo ""
            echo "Renumbering files..."

            # Create temp directory
            temp_dir="${OUTPUT_DIR}_temp"
            mkdir -p "$temp_dir"

            # Get remaining files in order
            remaining_files=($(ls -1 "$OUTPUT_DIR"/screen_*.txt 2>/dev/null | sort))

            # Copy to temp with new numbering
            counter=1
            for file in "${remaining_files[@]}"; do
                new_name=$(printf "screen_%04d.txt" "$counter")
                cp "$file" "$temp_dir/$new_name"
                ((counter++))
            done

            # Replace original directory
            rm -f "$OUTPUT_DIR"/screen_*.txt
            mv "$temp_dir"/* "$OUTPUT_DIR/"
            rmdir "$temp_dir"

            echo -e "${GREEN}Files renumbered: 1 to $kept_count${NC}"
        fi
    fi

    echo ""
    echo -e "${GREEN}Done!${NC}"
}

#
# MAIN
#
case "$MODE" in
    capture)
        capture_screenshots
        ;;
    dedupe)
        dedupe_screenshots
        ;;
    both)
        capture_screenshots
        # dedupe_screenshots will be called by the trap when Ctrl+C is pressed
        ;;
esac
