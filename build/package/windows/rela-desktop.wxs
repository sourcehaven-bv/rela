<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Rela Desktop"
           Manufacturer="Sourcehaven BV"
           Version="$(var.Version)"
           UpgradeCode="{6E5F7A2C-4D5B-4E3A-9F8C-8B7A6D5E4F3A}"
           Compressed="yes"
           Icon="rela-desktop.ico">

    <Icon Id="rela-desktop.ico" SourceFile="$(var.SourceDir)\rela-desktop.ico" />
    <Property Id="ARPPRODUCTICON" Value="rela-desktop.ico" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of Rela Desktop is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="Main" Title="Rela Desktop" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentGroupRef Id="ShortcutComponents" />
    </Feature>
  </Package>

  <Fragment>
    <StandardDirectory Id="ProgramFiles6432Folder">
      <Directory Id="INSTALLFOLDER" Name="Rela Desktop" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuDir" Name="Rela Desktop" />
    </StandardDirectory>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Component Id="MainExecutable">
        <File Id="RelaDesktopExe" Source="$(var.SourceDir)\rela-desktop.exe" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <Fragment>
    <ComponentGroup Id="ShortcutComponents" Directory="ProgramMenuDir">
      <Component Id="StartMenuShortcut">
        <Shortcut Id="StartMenuShortcut"
                  Name="Rela Desktop"
                  Target="[INSTALLFOLDER]rela-desktop.exe"
                  WorkingDirectory="INSTALLFOLDER"
                  Icon="rela-desktop.ico" />
        <RemoveFolder Id="RemoveProgramMenuDir" On="uninstall" />
        <RegistryValue Root="HKCU"
                       Key="Software\Sourcehaven\RelaDesktop"
                       Name="StartMenuShortcut"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>
</Wix>
